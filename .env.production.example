# Copy to .env.production and replace every placeholder through your deployment
# secret manager. Never commit the completed file.
APP_ENV=production
SECRET_KEY=replace-with-a-secret-manager-value-of-at-least-32-characters
DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@POSTGRES_HOST:5432/autoposter
PUBLIC_BASE_URL=https://autoposter.example.com
CORS_ORIGINS=https://autoposter.example.com
AUTH_TRANSPORT=bearer
DEV_AUTO_LOGIN=false
AUTO_CREATE_TABLES=false
JOB_PROCESS_INLINE=false
JOB_WORKER_POLL_SECONDS=5
JOB_WORKER_BATCH_SIZE=10
WORKER_HEARTBEAT_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
LOG_FORMAT=json

# Choose exactly one storage setup. For local storage, mount a persistent
# UPLOAD_VOLUME in docker-compose.production.yml and back it up with PostgreSQL.
STORAGE_BACKEND=local
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# For S3-compatible storage, set STORAGE_BACKEND=s3 and populate these via the
# deployment secret manager; the bucket must be private and included in backups.
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_KEY_PREFIX=uploads
