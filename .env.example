APP_NAME=Secondhand Platforms Autoposter
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-value
DATABASE_URL=sqlite:///./data/autoposter.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://autoposter:autoposter@postgres:5432/autoposter
UPLOAD_DIR=./data/uploads
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_KEY_PREFIX=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
CORS_ORIGINS=*
DEV_AUTO_LOGIN=false
AUTH_TRANSPORT=bearer
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
API_RATE_LIMIT_REQUESTS=300
API_RATE_LIMIT_WINDOW_SECONDS=60
AUTO_CREATE_TABLES=true
JOB_PROCESS_INLINE=true
JOB_WORKER_POLL_SECONDS=5
JOB_WORKER_BATCH_SIZE=10
WORKER_HEARTBEAT_TIMEOUT_SECONDS=30
JOB_STALE_RUNNING_SECONDS=1800
PLATFORM_RATE_LIMIT_SECONDS=60
# Optional comma-separated platform cooldown overrides, e.g. marktplaats=120,ebay=300
PLATFORM_RATE_LIMIT_OVERRIDES=
SESSION_EXPIRE_HOURS=168
AUDIT_RETENTION_DAYS=365
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,nl
PUBLIC_BASE_URL=http://127.0.0.1:8000
LOG_LEVEL=INFO
# Use text locally or json for production log aggregation.
LOG_FORMAT=text

# Optional eBay official API OAuth foundation. Leave blank unless using a real
# eBay developer application. Raw client secrets and tokens must live in a
# secret manager, not in this file or the app database.
EBAY_OAUTH_CLIENT_ID=
# Keep real client secrets in your deployment secret manager; this local value
# only enables the token-exchange code path when explicitly provided.
EBAY_OAUTH_CLIENT_SECRET=
EBAY_OAUTH_REDIRECT_URI=
EBAY_OAUTH_ENVIRONMENT=sandbox
EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account
EBAY_OAUTH_STATE_TTL_SECONDS=600
EBAY_TOKEN_SECRET_REF_PREFIX=secret://ebay/oauth
TOKEN_SECRET_DIR=./data/secrets

# Optional legacy Selenium scripts only. Do not commit real values.
LASTPASS_EMAIL=
LASTPASS_PASSWORD=
CHROME_DRIVER_PATH=/usr/local/bin/chromedriver
TWEEDEHANDS_URL=https://www.tweedehands.net/login.php
MIJNKOOPWAAR_URL=https://mijnkoopwaar.nl/login
NEXTDOOR_URL=https://nextdoor.com/login/
KOOPPLEIN_URL=https://koopplein.nl/nederland/gebruikers/login
MARKPLAATS_URL=https://www.marktplaats.nl
EBAY_URL=https://www.ebay.nl/mys/overview
SCRAPED_STATUS=true
